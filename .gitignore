# ====================================================================
# .GITIGNORE GLOBAL
# ====================================================================

# --- OS & IDEs ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Environnement ---
.env
.env.*
!.env.example
!.env.test

# --- FRONTEND (SvelteKit / Node) ---
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
frontend/.output/
frontend/.vercel/
frontend/.netlify/
frontend/.wrangler/
frontend/vite.config.js.timestamp-*
frontend/vite.config.ts.timestamp-*

# --- TAURI (Desktop Wrapper) ---
frontend/src-tauri/target/
# Ignorer ABSOLUMENT les binaires locaux (les sidecars générés)
frontend/src-tauri/bin/allnightlong-backend-*
frontend/src-tauri/bin/*.exe

# --- BACKEND (Python / uv) ---
backend/.venv/
backend/.uv/
backend/__pycache__/
backend/*.py[oc]
backend/*.egg-info/
backend/wheels/

# --- Générations PyInstaller (Compilations locales) ---
backend/build/
backend/dist/
backend/*.spec
backend/*.pkg
backend/*.exe
backend/warn-allnightlong-backend.txt
backend/xref-allnightlong-backend.html
backend/allnightlong.db
